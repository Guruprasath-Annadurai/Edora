<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_novo_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_novo"
    android:padding="14dp">

    <!-- ── Left column: Novo avatar circle + XP ──────────────────── -->
    <LinearLayout
        android:id="@+id/widget_left_col"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingEnd="12dp">

        <!-- Novo circle avatar -->
        <TextView
            android:id="@+id/widget_novo_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/widget_novo_circle"
            android:text="N"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Streak pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_streak_pill"
            android:paddingStart="7dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_widget_flame"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_streak_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Right column: main content ──────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_right_col"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/widget_left_col"
        android:orientation="vertical">

        <!-- Top row: NOVO label + exam badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NOVO"
                android:textColor="#7C3AED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <!-- Exam countdown badge (hidden when no exam) -->
            <TextView
                android:id="@+id/widget_exam_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_exam_pill"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="#EF4444"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Novo tip / today's question -->
        <TextView
            android:id="@+id/widget_tip"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Open Edora to start today's session"
            android:textColor="#E8E8F0"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- XP row -->
        <LinearLayout
            android:id="@+id/widget_xp_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_xp_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XP"
                android:textColor="#A855F7"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <ProgressBar
                android:id="@+id/widget_xp_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_weight="1"
                android:progressDrawable="@drawable/widget_xp_bar_fill"
                android:background="@drawable/widget_xp_bar_bg"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/widget_xp_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#A855F7"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Ask Novo button -->
        <TextView
            android:id="@+id/widget_ask_btn"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:background="@drawable/widget_action_btn"
            android:text="Ask Novo →"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</RelativeLayout>
