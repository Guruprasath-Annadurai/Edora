# ── Edora Release Keystore ────────────────────────────────────────────────────
# Copy this file to keystore.properties and fill in real values.
# NEVER commit keystore.properties or the .jks file to git.
#
# Generate your keystore with:
#   keytool -genkey -v -keystore edora-release.jks \
#     -alias edora -keyalg RSA -keysize 2048 -validity 10000
#
# Then copy edora-release.jks into the android/ folder and fill in below.
# ─────────────────────────────────────────────────────────────────────────────

storeFile=../edora-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=edora
keyPassword=YOUR_KEY_PASSWORD
