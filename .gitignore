# Android release signing — contains keystore password in plaintext
android/keystore.properties
android/*.jks
android/*.keystore

# TS incremental build cache — machine-specific, regenerated on build
*.tsbuildinfo

# gstack skill tool-local state — not project source
.gstack/

# Signed release build artifacts — not source, regenerated per release
release-builds/
